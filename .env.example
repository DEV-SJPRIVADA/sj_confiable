APP_NAME="SJ_CONFIABLE"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/Bogota

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Base de datos ---
# Local (Laragon): sj_confiable / root
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sj_confiable
DB_USERNAME=root
DB_PASSWORD=

# Hosting UAT/prod (ejemplo Hostinger — usar BD dedicada, nunca la de producción):
# DB_HOST=localhost
# DB_DATABASE=uXXXXXX_sjconf_uat
# DB_USERNAME=uXXXXXX_sjconf_uat
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Dominios stateful (Sanctum). Local: hosts Laragon; hosting: solo el subdominio público.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1
# SANCTUM_STATEFUL_DOMAINS=uat.sjconfiable.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Correo (avisos de solicitud = campana del panel) ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_NOTIFICATIONS_ENABLED=true
# UAT/prod SMTP (ejemplo Microsoft 365):
# MAIL_MAILER=smtp
# MAIL_SCHEME=smtp
# MAIL_HOST=smtp.office365.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM_ADDRESS=
# MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- SJ Confiable: semillas y datos de prueba (solo local) ---
# Tras db:seed en local, contraseñas usuarios id 1–7 = SEED_ADMIN_PASSWORD
SEED_ADMIN_PASSWORD=change_me_local
SEED_LEGACY_OPERATIONAL=true
SEED_DEV_PASSWORDS=true
RUN_LEGACY_SQL_IMPORT=false

# PDFs del sistema anterior (ruta absoluta en el servidor donde corre Laravel).
# Local Windows: C:\ruta\a\uploads
# Hosting Linux: /home/usuario/domains/ejemplo.com/public_html/uat/storage/app/public/uploads
# LEGACY_DOCUMENTS_ROOT=

# --- Hosting UAT: copiar estas líneas al .env del servidor ---
# APP_ENV=staging
# APP_DEBUG=true
# APP_URL=https://uat.sjconfiable.com
# RUN_LEGACY_SQL_IMPORT=false
# SEED_DEV_PASSWORDS=false
# LEGACY_DOCUMENTS_ROOT=/home/usuario/.../uat/storage/app/public/uploads

# --- SJ: pantalla de login (opcional) ---
# SJ_WHATSAPP_URL=https://wa.me/57XXXXXXXXX
# SJ_FORGOT_PASSWORD_URL=
# SJ_SOCIAL_FACEBOOK=
# SJ_SOCIAL_LINKEDIN=
# SJ_SOCIAL_INSTAGRAM=
